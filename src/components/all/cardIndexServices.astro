---
import { Icon } from 'astro-icon/components'

interface Service {
	iconName: string
	title: string
	description: string
}

const { iconName, title, description } = Astro.props as Service
---

<article class="p-6 rounded-2xl bg-gray-100 w-full h-full">
	<Icon name={`ph:${iconName}`} class="size-8 text-purple-950 mb-2" />
	<h4 class="text-balance text-purple-950 mb-h4">{title}</h4>
	<p class="text-pretty">{description}</p>
</article>